  number: 1
  text: "\u041A\u0430\u043A\u043E\u0439 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u0448\u0442\u0430\u0442 \u043F\u0435\u0440\u0432\u044B\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0443\u0437\u0430\u043A\u043E\u043D\u0438\u043B DAO (\u0434\u0435\u0446\u0435\u043D\u0442\u0440\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0430\u0432\u0442\u043E\u043D\u043E\u043C\u043D\u044B\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438)
    \u043A\u0430\u043A \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043B\u0438\u0446\u043E?"
  answers:
  - isTrue: 0
    text: "\u041D\u044C\u044E-\u0419\u043E\u0440\u043A"
  - isTrue: 0
    text: "\u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u044F"
  - isTrue: 1
    text: "\u0412\u0430\u0439\u043E\u043C\u0438\u043D\u0433"
  - isTrue: 0
    text: "\u0422\u0435\u0445\u0430\u0441"
