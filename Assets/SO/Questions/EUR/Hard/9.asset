  text: "\u041A\u0430\u043A\u043E\u0439 \u0433\u043E\u0440\u043E\u0434 \u0441\u0442\u0430\u043B
    \u043F\u0435\u0440\u0432\u044B\u043C \u0432 \u0415\u0432\u0440\u043E\u043F\u0435,
    \u0433\u0434\u0435 \u0431\u0438\u0442\u043A\u043E\u0438\u043D \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0441\u0435\u043A\u0442\u043E\u0440\u0435?"
  answers:
  - isTrue: 0
    text: "\u0411\u0435\u0440\u043B\u0438\u043D"
  - isTrue: 1
    text: "\u041B\u0443\u0433\u0430\u043D\u043E"
