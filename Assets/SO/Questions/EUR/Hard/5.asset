  text: "\u041A\u0430\u043A\u0430\u044F \u0441\u0442\u0440\u0430\u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0437\u0430\u043F\u0443\u0441\u0442\u0438\u043B\u0430
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0435\u0433\u0443\u043B\u0438\u0440\u0443\u0435\u043C\u044B\u0439
    \u0444\u043E\u043D\u0434\u043E\u0432\u044B\u0439 \u0442\u043E\u043A\u0435\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0440\u044B\u043D\u043E\u043A?"
  answers:
  - isTrue: 0
    text: "\u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F"
  - isTrue: 1
    text: "\u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0438\u044F"
  - isTrue: 0
    text: "\u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u044F"
  - isTrue: 0
    text: "\u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u044B"
