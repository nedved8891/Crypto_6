  m_Script: {fileID: 11500000, guid: 459810b2bdc973844ab6b97a0e6f2fa6, type: 3}
  m_Name: 7
  m_EditorClassIdentifier: 
  number: 7
  text: "\u041A\u0430\u043A\u043E\u0439 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0439
    \u0440\u0435\u0433\u0443\u043B\u044F\u0442\u043E\u0440 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439 MiCA (Markets
    in Crypto-Assets Regulation)?"
  answers:
  - isTrue: 0
    text: "\u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0430\u044F \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044F"
  - isTrue: 1
    text: "\u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0439 \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442"
  - isTrue: 0
    text: "\u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0439 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0439
      \u0431\u0430\u043D\u043A"
  - isTrue: 0
    text: ESMA
