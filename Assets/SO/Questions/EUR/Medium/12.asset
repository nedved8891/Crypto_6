  text: "\u041A\u0430\u043A\u0430\u044F \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u044B\u043C
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u043E\u043C, \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u043C
    \u0431\u043B\u043E\u043A\u0447\u0435\u0439\u043D \u0432 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0440\u0435\u0435\u0441\u0442\u0440\u044B?"
  answers:
  - isTrue: 1
    text: "\u042D\u0441\u0442\u043E\u043D\u0438\u044F"
