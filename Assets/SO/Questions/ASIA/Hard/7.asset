  number: 7
  text: "\u041A\u0430\u043A\u0430\u044F \u0430\u0437\u0438\u0430\u0442\u0441\u043A\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u0439 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043B\u0430
    \u043A\u0440\u0438\u043F\u0442\u043E\u0432\u0430\u043B\u044E\u0442\u043D\u044B\u0435
    ETF (\u0431\u0438\u0440\u0436\u0435\u0432\u044B\u0435 \u0438\u043D\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0444\u043E\u043D\u0434\u044B)?"
  answers:
  - isTrue: 1
    text: "\u0413\u043E\u043D\u043A\u043E\u043D\u0433"
  - isTrue: 0
    text: "\u042F\u043F\u043E\u043D\u0438\u044F"
  - isTrue: 0
    text: "\u042E\u0436\u043D\u0430\u044F \u041A\u043E\u0440\u0435\u044F"
  - isTrue: 0
    text: "\u0422\u0430\u0438\u043B\u0430\u043D\u0434"
