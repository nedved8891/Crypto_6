  number: 5
  text: "\u0412 \u043A\u0430\u043A\u043E\u043C \u0430\u0437\u0438\u0430\u0442\u0441\u043A\u043E\u043C
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435 \u043A\u0440\u0438\u043F\u0442\u043E\u0431\u0438\u0440\u0436\u0438
    \u043E\u0431\u044F\u0437\u0430\u043D\u044B \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0442\u044C
    \u0434\u0430\u043D\u043D\u044B\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u043C \u043E\u0440\u0433\u0430\u043D\u0430\u043C?"
  answers:
  - isTrue: 1
    text: "\u042E\u0436\u043D\u0430\u044F \u041A\u043E\u0440\u0435\u044F"
  - isTrue: 0
    text: "\u0412\u044C\u0435\u0442\u043D\u0430\u043C"
  - isTrue: 0
    text: "\u0424\u0438\u043B\u0438\u043F\u043F\u0438\u043D\u044B"
  - isTrue: 0
    text: "\u041A\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043D"
