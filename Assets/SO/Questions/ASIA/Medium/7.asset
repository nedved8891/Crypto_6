  text: "\u0412 \u043A\u0430\u043A\u043E\u0439 \u0430\u0437\u0438\u0430\u0442\u0441\u043A\u043E\u0439
    \u0441\u0442\u0440\u0430\u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u0431\u043B\u043E\u043A\u0447\u0435\u0439\u043D-\u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439?"
  answers:
  - isTrue: 0
    text: "\u0412\u044C\u0435\u0442\u043D\u0430\u043C"
  - isTrue: 0
    text: "\u0418\u043D\u0434\u043E\u043D\u0435\u0437\u0438\u044F"
  - isTrue: 1
    text: "\u041E\u0410\u042D"
  - isTrue: 0
    text: "\u0421\u0430\u0443\u0434\u043E\u0432\u0441\u043A\u0430\u044F \u0410\u0440\u0430\u0432\u0438\u044F"
